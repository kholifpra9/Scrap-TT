# Groq API Key
# Daftar gratis di: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Personalisasi AI
AI_SYSTEM_PROMPT=Kamu adalah analis bisnis senior yang berpengalaman di pasar herbal dan kesehatan tradisional Indonesia. Jawab tajam dan actionable.
AI_BISNIS=Produk Herbal
AI_INDUSTRI=Herbal & Kesehatan Tradisional
AI_TONE=semi-formal

# (Opsional) Port server, default 3000
PORT=3000

# Limitasi penggunaan
RATE_RESET_HOUR=8
RATE_LIMIT_MAX=5        # default 5x/hari
RATE_LIMIT_WINDOW=86400000  # default 24 jam (ms)
